# === Google Cloud OAuth client (see README.md for Console setup steps) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/callback

# === Storage ===
# Path to the SQLite file shared with the D.R.A.K.E. bot. Relative paths resolve
# from the health/ directory.
HEALTH_DB_PATH=../data/database/agent.db

# Where the refreshable OAuth token is cached after first auth. Never commit this file.
HEALTH_TOKEN_PATH=./.token.json
